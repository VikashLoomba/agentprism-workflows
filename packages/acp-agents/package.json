{
  "name": "@agentprism/acp-agents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "build:codex-vendor": "cd vendor/codex-acp && npm install && npm run build"
  },
  "dependencies": {
    "@agentprism/shared-types": "workspace:*",
    "@agentclientprotocol/sdk": "1.0.0",
    "@agentclientprotocol/claude-agent-acp": "0.53.0",
    "typebox": "1.3.2"
  }
}
