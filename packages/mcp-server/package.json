{
  "name": "@automatalabs/mcp-server",
  "version": "0.1.3",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VikashLoomba/agentprism-workflows.git",
    "directory": "packages/mcp-server"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "bin": {
    "agentprism-workflow": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
      "agentprism-workflow": "./dist/index.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"test/**/*.test.ts\"",
    "prepublishOnly": "tsc -b"
  },
  "dependencies": {
    "@automatalabs/workflows": "workspace:*",
    "@automatalabs/shared-types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29",
    "zod": "^4.0.0"
  }
}
